# ════════════════════════════════════
#  GHOST PLAGUE CASINO — .env.example
#  Copy this file to .env and fill in
#  your real credentials.
#  NEVER commit the real .env to Git.
# ════════════════════════════════════

# ── Server ────────────────────────────
PORT=10000

# ── Firebase Admin SDK ─────────────────
# Get these from Firebase Console →
# Project Settings → Service Accounts →
# Generate new private key (JSON file)

FIREBASE_PROJECT_ID=ghost-plague-casino
FIREBASE_DATABASE_URL=https://ghost-plague-casino-default-rtdb.firebaseio.com
FIREBASE_PRIVATE_KEY_ID=your_private_key_id_here
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ghost-plague-casino.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=000000000000000000000
FIREBASE_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40ghost-plague-casino.iam.gserviceaccount.com

# ── Telegram Bot ───────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Render (auto-set by Render, do NOT add manually) ──
# RENDER_SERVICE_NAME=ghost-plague-casino
